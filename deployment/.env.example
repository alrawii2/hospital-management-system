# ---------------------------------------------------------------------------
# Hospital Management System — environment variables for docker-compose
# ---------------------------------------------------------------------------
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# real values. NEVER commit `.env` itself — only this example.
#
#   cp .env.example .env
#   # then edit .env
# ---------------------------------------------------------------------------

# --- Django ---
# Generate via:  python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=change-me-to-a-64-char-random-string

# Comma-separated list. Add your prod hostname here.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Field encryption (django-encrypted-model-fields) ---
# Fernet key — 44-char urlsafe base64.
# Generate via:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# IMPORTANT: rotating this key without a data migration makes existing
# encrypted columns unreadable.
FIELD_ENCRYPTION_KEY=change-me-to-a-44-char-fernet-key

# --- PostgreSQL ---
POSTGRES_DB=hms
POSTGRES_USER=hms_user
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Public-facing port for Nginx (default 80) ---
HMS_PUBLIC_PORT=80

# --- Seed demo data on first start (1 = yes, 0 = no) ---
# Turn this on for the first `docker compose up`, then set back to 0.
HMS_SEED_ON_START=1
